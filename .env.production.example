# Contoh environment produksi. Di Coolify, set variabel ini di panel resource
# (Build/Environment Variables). Jangan commit file .env sungguhan.

# Database MariaDB. Di Coolify: tambahkan database MariaDB sebagai service lalu
# hubungkan ke aplikasi — DATABASE_URL ter-inject otomatis. Format manual:
# mysql://USER:PASSWORD@HOST:3306/DBNAME
DATABASE_URL=mysql://user:password@host:3306/rpp_sync

# URL publik aplikasi (domain/subdomain sekolah yang Anda punya).
NEXTAUTH_URL=https://rpp.sekolah.sch.id

# Secret NextAuth. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=ganti-dengan-string-acak-panjang

# Password admin awal (WAJIB di produksi). Seed membuat akun
# admin@gqtunasilmu.sch.id / username: admin dengan password ini.
ADMIN_PASSWORD=ganti-password-kuat

# Opsional: set "true" untuk membuat data contoh (Mapel "Al-Qur'an" & Kelas
# "1 Ikhwan") saat seed di produksi. Default kosong = hanya admin.
SEED_DEMO=